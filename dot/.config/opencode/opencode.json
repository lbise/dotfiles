{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.4",
  "small_model": "github-copilot/gpt-5-mini",
  "share": "disabled",
  "autoupdate": false,
  "instructions": ["ai_notes/conventions.md"],
  "permission": {
    "external_directory": {
      "~/**": "allow",
      "/tmp/**": "allow",
    }
  },
  "formatter": {
    "clang-format": {
      "command": [
        "clang-format",
        "--style-file={env:$ANDROMEDA_ROOT}/hooks/.clang-format",
        "-i $FILE"
      ],
      "extensions": [".c", ".cpp", ".h", ".hpp", ".ino", ".unity"]
    },
    "ruff": {
      "command": [
        "ruff",
        "format",
        "$FILE",
        "--config {env:$ANDROMEDA_ROOT}/pyproject.toml"
      ],
      "extensions": [".py", ".pyi"]
    }
  },
  "lsp": {
    "clangd": {
      "disabled": true
    },
    "pyright": {
      "disabled": true
    },
    "basedpyright": {
      "command": ["basedpyright-langserver", "--stdio"],
      "extensions": [".py"],
      "initialization": {
        "typeCheckingMode": "all",
        "extraPaths": [
          "{env:$HOME}/andromeda",
          "{env:$HOME}/andromeda/apps/scripts/python",
          "{env:$HOME}/andromeda/bt/scripts/python",
          "{env:$HOME}/andromeda/buildsystem/scripts/python",
          "{env:$HOME}/andromeda/dsp/scripts/python",
          "{env:$HOME}/andromeda/executer/scripts/python",
          "{env:$HOME}/andromeda/hlc/scripts/python",
          "{env:$HOME}/andromeda/infrastructure/scripts/python",
          "{env:$HOME}/andromeda/pctools/scripts/python",
          "{env:$HOME}/andromeda/raspi4/scripts/python",
          "{env:$HOME}/andromeda/rom/scripts/python",
          "{env:$HOME}/andromeda/stf4/scripts/python",
          "{env:$HOME}/andromeda/tstenv/scripts/python",
          "{env:$HOME}/andromeda/nordic/scripts/python"
        ]
      }
    }
  },
  "provider": {
    "azure-anthropic": {
      "name": "Azure AI Foundry (Anthropic)",
      "npm": "@ai-sdk/anthropic",
      "api": "{env:AZURE_API_BASE}",
      "env": ["AZURE_API_KEY"],
      "models": {
        "claude-opus-4-5": {
          "id": "claude-opus-4-5",
          "name": "Claude Opus 4.5",
          "tool_call": true,
          "attachment": true,
          "reasoning": true,
          "temperature": true
        },
        "claude-sonnet-4-5": {
          "id": "claude-sonnet-4-5",
          "name": "Claude Sonnet 4.5",
          "tool_call": true,
          "attachment": true,
          "reasoning": true,
          "temperature": true,
          "options": {
            "thinking": {
              "type": "enabled",
              "budgetTokens": 16000
            }
          }
        },
        "claude-haiku-4-5": {
          "id": "claude-haiku-4-5",
          "name": "Claude Haiku 4.5",
          "tool_call": true,
          "attachment": true,
          "reasoning": true,
          "temperature": true,
          "options": {
            "thinking": {
              "type": "enabled",
              "budgetTokens": 16000
            }
          }
        }
      }
    }
  }
}
